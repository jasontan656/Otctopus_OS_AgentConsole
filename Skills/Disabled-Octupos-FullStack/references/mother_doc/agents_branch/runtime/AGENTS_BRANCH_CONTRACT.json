{
  "schema_version": "3.0",
  "branch_name": "mother_doc_agents_manager",
  "runtime_source_policy": {
    "primary_runtime_source": "branch_contract_json",
    "target_runtime_source": "target_contract_json"
  },
  "scope_policy": {
    "managed_external_target": "<root>/Octopus_OS/AGENTS.md",
    "managed_target_count": 1,
    "forbidden_extra_agents": true
  },
  "managed_asset_model": {
    "external_shape": "part_a_only",
    "internal_human_shape": "part_a_plus_part_b",
    "internal_machine_shape": "part_b_only",
    "managed_human_path": "assets/managed_targets/Octopus_OS/AGENTS_human.md",
    "managed_machine_path": "assets/managed_targets/Octopus_OS/AGENTS_machine.json",
    "scan_report_path": "assets/mother_doc_agents/scan_report.json"
  },
  "runtime_entry_commands": {
    "branch_contract_command": "./.venv_backend_skills/bin/python Skills/Disabled-Octupos-FullStack/scripts/Cli_Toolbox.py mother-doc-agents-contract --json",
    "stage_directive_command": "./.venv_backend_skills/bin/python Skills/Disabled-Octupos-FullStack/scripts/Cli_Toolbox.py mother-doc-agents-directive --stage <scan|collect|push> --json",
    "target_contract_command": "./.venv_backend_skills/bin/python Skills/Disabled-Octupos-FullStack/scripts/Cli_Toolbox.py mother-doc-agents-target-contract --relative-path \"octopus_os_root\" --file-kind agents --json"
  },
  "stage_order": [
    "scan",
    "collect",
    "push"
  ]
}
