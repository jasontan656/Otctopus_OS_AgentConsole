{
  "contract_name": "meta_rootfile_manager_skill_runtime_contract",
  "version": "2.0.0",
  "tool_entry": {
    "commands": {
      "contract": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py contract --json",
      "scan": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py scan --json",
      "lint": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py lint --json",
      "collect": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py collect --json",
      "push": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py push --json",
      "scaffold": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py scaffold --json",
      "new_writeback": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py new-writeback --json",
      "target_contract": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py target-contract --source-path \"<external path>\" --json",
      "agents_maintain": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py agents-maintain --intent \"<natural language request>\" --json",
      "agents_domain_contract": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py agents-domain-contract --source-path \"<external AGENTS path>\" --domain \"<domain_id>\" --json",
      "agents_payload_contract": "./.venv_backend_skills/bin/python Skills/Meta-RootFile-Manager/scripts/Cli_Toolbox.py agents-payload-contract --source-path \"<external AGENTS path>\" --json"
    }
  },
  "rules": [
    "Treat visible AGENTS.md as a full runtime hook contract, not as loose narrative plus hidden contract.",
    "Treat reminder as a tail-only non-executable section.",
    "Treat Part B as split domain blocks with one block per domain.",
    "Use agents-maintain as the daily AGENTS maintenance mainline.",
    "Use agents-domain-contract to read a single domain block.",
    "Use agents-payload-contract only for narrow domain-block surgery."
  ],
  "artifact_policy": {
    "mode": "runtime_local_artifacts",
    "resolver": "runtime_contract_paths",
    "notes": [
      "Codex_Skill_Runtime/<skill>/artifacts/<stage>/latest.json remains the canonical runtime artifact path."
    ]
  }
}
