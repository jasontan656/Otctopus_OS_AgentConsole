{
  "version": 1,
  "contract_name": "meta_default_md_manager_scan_ruleset_contract",
  "contract_version": "2.0.0",
  "validation_mode": "archival",
  "tool_state": "active",
  "required_fields": [
    "contract_name",
    "contract_version",
    "validation_mode"
  ],
  "optional_fields": [
    "notes"
  ],
  "scan_rule_assets": {
    "channel_registry": {
      "required": true,
      "description": "Static channel registry only; dynamic governed targets must not be embedded here."
    },
    "disallowed_list": {
      "required": true,
      "source_type": "external_rule_asset",
      "description": "Blacklist-driven path exclusion for governed scan results."
    },
    "exact_filename_rules": {
      "required": true,
      "default_values": [
        "AGENTS.md"
      ],
      "description": "Exact managed filenames."
    },
    "keyword_rules": {
      "required": false,
      "supported_shape": {
        "keyword": "contract",
        "file_ext": "*.md"
      },
      "description": "Optional keyword-driven file discovery rules."
    }
  },
  "managed_boundary": {
    "current_governed_filename_set": [
      "AGENTS.md"
    ],
    "dynamic_target_discovery_rule": "derive governed targets from managed asset trees under assets/managed_targets and Codex_Skill_Runtime/<skill>/managed_targets",
    "default_disallowed_roots": [
      "Octopus_OS"
    ]
  },
  "output_policy": {
    "allowed_modes": [
      "stdout",
      "json"
    ],
    "json_output_must_write_under": "Codex_Skill_Runtime/<skill_name>/artifacts/scan/"
  },
  "lint_policy": {
    "run_after_scan": true,
    "fail_if_structure_template_missing": true,
    "structure_template_map": {
      "AGENTS.md": "references/runtime_contracts/AGENTS_content_structure.md"
    }
  }
}
