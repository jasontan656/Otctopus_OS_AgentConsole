{
  "contract_name": "DEV_VUE3_WEBUI_FRONTEND_DOCGRAPH_CONTRACT",
  "contract_version": "v1",
  "skill_name": "dev-vue3-webui-frontend",
  "scope": "skill_internal_markdown_graph_for_showroom",
  "primary_goal": "Provide anchor-based markdown graph data so the frontend showroom can render the current skill as a live document graph.",
  "thinking_chain": [
    "scope_check",
    "doc_inventory",
    "frontmatter_contract_check",
    "anchor_graph_check",
    "atomicity_signal_check",
    "rewrite_or_split",
    "graph_emit"
  ],
  "commands": {
    "build_anchor_graph": "npm run cli -- build-anchor-graph --target <skill_root> --json",
    "rebuild_self_graph": "npm run cli -- rebuild-self-graph --json"
  },
  "frontmatter_contract": {
    "template_path": "assets/templates/DOC_FRONTMATTER_TEMPLATE.yaml",
    "required_fields": [
      "doc_id",
      "doc_type",
      "topic",
      "anchors"
    ],
    "skill_md_metadata_path": "metadata.doc_structure"
  },
  "graph_contract": {
    "matrix_path": "assets/runtime/anchor_query_matrix.json",
    "self_graph_path": "assets/runtime/self_anchor_graph.json",
    "min_anchor_count_per_doc": 1,
    "target_must_be_markdown": true
  }
}
