###############################################
# Rise_Lab - ignore: envs, deps, caches, logs
# Keep Temp/tmp folders (no Temp/tmp patterns here)
###############################################

# --- Secrets ---
.env
.env.*
!.env.example
!.env.template
!.env.sample

# --- Logs ---
log/
logs/
Log/
Logs/
LOG/
LOGS/
*.log
*.log.*

# --- Python virtual envs ---
.venv/
.venv*/
venv/
env/
ENV/
.venv-wsl/

# --- Python caches ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
*.egg-info/

# --- Node deps & caches ---
node_modules/
