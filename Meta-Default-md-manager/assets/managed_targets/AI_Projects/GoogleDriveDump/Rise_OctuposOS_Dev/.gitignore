.npm/
.yarn/
.yarn-cache/
.vite/
.turbo/
.parcel-cache/
.next/cache/
.nuxt/cache/

# --- General caches ---
.cache/

# --- Local helper files (never commit) ---
.codex_skill_roots/
Rise/AI_WorkSpace/OpenClaw/
Rise/AI_WorkSpace/Temp/front.md

# --- Auto-generated promote reports (never commit) ---
Rise/AI_WorkSpace/Temp/promote_*.md

# --- OctuposOS runtime artifacts (standalone repo, AI-maintained) ---
