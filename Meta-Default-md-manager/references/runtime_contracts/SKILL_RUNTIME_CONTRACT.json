{
  "version": 2,
  "skill_name": "Meta-Default-md-manager",
  "description": "Meta-Default-md-manager exposes scan, lint, collect, push, and target-contract CLI commands governed by static runtime contracts.",
  "skill_state": "active_tools",
  "runtime_access_policy": {
    "guidance_source": "static_runtime_contracts_plus_cli",
    "markdown_role": "human_governance_and_archive",
    "model_must_not_invent_removed_cli_commands": true,
    "model_must_not_treat_legacy_tooling_docs_as_active_runtime": true
  },
  "command_map": {
    "scaffold": "scripts/Cli_Toolbox.py scaffold",
    "scan": "scripts/Cli_Toolbox.py scan",
    "lint": "scripts/Cli_Toolbox.py lint",
    "collect": "scripts/Cli_Toolbox.py collect",
    "push": "scripts/Cli_Toolbox.py push",
    "target-contract": "scripts/Cli_Toolbox.py target-contract"
  },
  "asset_maintenance_policy": {
    "agents_human_template_must_use_explicit_part_tags": true,
    "external_agents_md_contains_part_a_only": true,
    "internal_agents_human_contains_part_a_and_part_b": true,
    "agents_machine_json_contains_part_b_only": true,
    "agents_changes_require_joint_part_a_part_b_review": true,
    "root_agents_and_root_internal_assets_excluded_from_this_cleanup_round": true
  },
  "scan_collect_push_state": {
    "scaffold": "active_cli_for_governed_directory_skeleton_creation",
    "new-file": "documentation_first_stage",
    "scan": "active_cli_with_external_rule_assets",
    "collect": "active_cli_with_external_source_as_truth_and_dual_sync",
    "push": "active_cli_with_internal_template_as_truth"
  },
  "tool_capabilities": {
    "dry_run_supported_for_all_write_stages": true,
    "exact_source_path_filter_supported": true,
    "runtime_report_override_supported": true
  },
  "contract_name": "meta_default_md_manager_runtime_contract",
  "contract_version": "3.0.0",
  "validation_mode": "active",
  "required_fields": [
    "contract_name",
    "contract_version",
    "validation_mode"
  ],
  "optional_fields": [
    "notes"
  ],
  "governed_agents_contract": {
    "external_agents_shape": "part_a_only",
    "internal_human_shape": "part_a_plus_part_b",
    "internal_machine_shape": "part_b_only"
  }
}
