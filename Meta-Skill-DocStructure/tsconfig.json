{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "ui/src/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ]
    }
  },
  "include": [
    "scripts/**/*.ts",
    "server/**/*.ts",
    "src/**/*.ts",
    "ui/src/**/*.ts",
    "ui/src/**/*.vue",
    "tests/**/*.ts",
    "vite.config.ts"
  ]
}
