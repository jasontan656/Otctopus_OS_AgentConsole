{
  "matrix_name": "META_SKILL_DOCSTRUCTURE_ANCHOR_QUERY_MATRIX",
  "matrix_version": "v1",
  "scope": "skill_internal_markdown_docs",
  "required_frontmatter_fields": [
    "doc_id",
    "doc_type",
    "topic",
    "anchors"
  ],
  "required_anchor_fields": [
    "target",
    "relation",
    "direction",
    "reason"
  ],
  "allowed_directions": [
    "upstream",
    "downstream",
    "lateral",
    "cross"
  ],
  "hard_rules": [
    "every markdown doc must expose at least one anchor",
    "anchor targets must resolve inside the same skill root",
    "anchor targets must point to real markdown docs"
  ],
  "anchor_query_semantics": [
    {
      "query": "上游规范",
      "relations": [
        "governed_by",
        "conforms_to",
        "expands"
      ],
      "directions": [
        "upstream"
      ],
      "keywords": [
        "规则",
        "规范",
        "contract",
        "runtime",
        "schema"
      ]
    },
    {
      "query": "下游执行",
      "relations": [
        "implements",
        "executed_via",
        "details"
      ],
      "directions": [
        "downstream"
      ],
      "keywords": [
        "脚本",
        "lint",
        "graph",
        "tool",
        "template"
      ]
    },
    {
      "query": "横向补充",
      "relations": [
        "pairs_with",
        "indexes",
        "tracks_changes_to"
      ],
      "directions": [
        "lateral",
        "cross"
      ],
      "keywords": [
        "补充",
        "索引",
        "变更",
        "分类"
      ]
    }
  ],
  "split_keyword_rules": [
    {
      "rule_id": "title_conjunction_zh",
      "scope": "title",
      "keywords": [
        "和",
        "以及",
        "兼",
        "并且",
        "同时"
      ],
      "threshold": 1,
      "severity": "warn",
      "message": "标题可能承载多个 topic，考虑拆分。"
    },
    {
      "rule_id": "title_conjunction_en",
      "scope": "title",
      "keywords": [
        " and ",
        " & ",
        " plus ",
        " vs "
      ],
      "threshold": 1,
      "severity": "warn",
      "message": "The title may bundle multiple topics; consider splitting."
    },
    {
      "rule_id": "body_axis_overload",
      "scope": "body",
      "keywords": [
        "定义",
        "流程",
        "脚本",
        "lint",
        "模板",
        "测试",
        "运行时",
        "架构"
      ],
      "threshold": 4,
      "severity": "warn",
      "message": "正文跨越过多轴线，可能需要进一步原子化。"
    }
  ]
}
