{
  "contract_name": "META_SKILL_DOCSTRUCTURE_RUNTIME_CONTRACT",
  "contract_version": "v4",
  "skill_name": "meta-skill-docstructure",
  "scope": "skill_internal_docs_only",
  "primary_goal": "Govern markdown document organization inside a skill folder with anchors, graph JSON, and a TypeScript CLI.",
  "thinking_chain": [
    "scope_check",
    "doc_inventory",
    "frontmatter_contract_check",
    "anchor_graph_check",
    "atomicity_signal_check",
    "rewrite_or_split",
    "graph_emit"
  ],
  "commands": {
    "runtime_contract": "npm run cli -- runtime-contract --json",
    "lint_doc_anchors": "npm run cli -- lint-doc-anchors --target <skill_root> --json",
    "build_anchor_graph": "npm run cli -- build-anchor-graph --target <skill_root> --json",
    "rebuild_self_graph": "npm run cli -- rebuild-self-graph --json"
  },
  "frontmatter_contract": {
    "template_path": "assets/templates/DOC_FRONTMATTER_TEMPLATE.yaml",
    "required_fields": [
      "doc_id",
      "doc_type",
      "topic",
      "anchors"
    ],
    "skill_md_metadata_path": "metadata.doc_structure"
  },
  "graph_contract": {
    "matrix_path": "assets/runtime/anchor_query_matrix.json",
    "self_graph_path": "assets/runtime/self_anchor_graph.json",
    "min_anchor_count_per_doc": 1,
    "target_must_be_markdown": true
  }
}
