{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "client/src/*"
      ]
    }
  },
  "include": [
    "lib/**/*.ts",
    "client/src/**/*.ts",
    "client/src/**/*.vue",
    "server/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vite.config.ts"
  ]
}
