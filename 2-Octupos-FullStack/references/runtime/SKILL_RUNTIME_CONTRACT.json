{
  "schema_version": "2.0",
  "skill_name": "2-Octupos-FullStack",
  "runtime_source_policy": {
    "skill_runtime_source": "CLI_JSON",
    "skill_markdown_role": "human_navigation_only",
    "model_must_prefer_cli_runtime_output": true
  },
  "mother_doc_governance": {
    "mother_doc_navigation_mode": "readme_and_scope_doc_only",
    "octopus_os_agents_mode": "single_root_target_only",
    "octopus_os_root_agents_path": "${AI_PROJECTS_ROOT:-$HOME/AI_Projects}/Octopus_OS/AGENTS.md"
  },
  "specialized_runtime_entries": {
    "mother_doc_agents_manager": {
      "branch_contract_command": "python3 scripts/Cli_Toolbox.py mother-doc-agents-contract --json",
      "branch_registry_command": "python3 scripts/Cli_Toolbox.py mother-doc-agents-registry --json",
      "target_contract_command": "python3 scripts/Cli_Toolbox.py mother-doc-agents-target-contract --relative-path \"octopus_os_root\" --file-kind agents --json"
    }
  }
}
