{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Docs Structured",
  "type": "object",
  "required": ["schema_version", "managed_skill", "tools"],
  "properties": {
    "schema_version": {"type": "string"},
    "managed_skill": {"type": "string"},
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "usage", "modification", "development"],
        "properties": {
          "tool_id": {"type": "string"},
          "usage": {"type": "object"},
          "modification": {"type": "object"},
          "development": {"type": "object"}
        }
      }
    }
  }
}
