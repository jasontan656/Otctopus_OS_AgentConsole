{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Registry",
  "type": "object",
  "required": ["instance_id", "managed_skill", "tools"],
  "properties": {
    "instance_id": {"type": "string"},
    "managed_skill": {"type": "string"},
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_id", "entrypoint", "owner", "status"],
        "properties": {
          "tool_id": {"type": "string"},
          "entrypoint": {"type": "string"},
          "owner": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    }
  }
}
